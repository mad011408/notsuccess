# NEXUS AI Agent - Environment Variables
# TryBons AI Configuration

# ===================
# TryBons AI API Configuration
# ===================

# API Key (Required)
API_KEY=sk_cr_CLACzLNP4e7FGgNFLZ3NuaT25vaJQj3hMPufwsYZG4oG

# Base URL
API_BASE_URL=https://go.trybons.ai

# ===================
# Model Settings
# ===================

# Default model (choose from available models)
# Available: claude-opus-4-1-20250805, claude-opus-4-5, claude-opus-4-5-20251101
DEFAULT_MODEL=claude-opus-4-5

# Default temperature (0.0 - 2.0)
DEFAULT_TEMPERATURE=0.7

# Default max tokens
DEFAULT_MAX_TOKENS=40960

# ===================
# Vector Store
# ===================

# ChromaDB (default - no config needed for local)
VECTOR_STORE_TYPE=chromadb

# Pinecone (optional)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=your-environment

# Qdrant (optional)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key

# ===================
# Database
# ===================

# PostgreSQL (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/nexus

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# ===================
# Application Settings
# ===================

# Environment
ENVIRONMENT=development

# Debug mode
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# ===================
# Security
# ===================

# Secret key for JWT tokens
SECRET_KEY=your-secret-key-change-in-production

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
